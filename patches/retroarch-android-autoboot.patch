+	// Copie l'URI choisi vers romFile(). true si OK et entete ZIP valide.
+	private boolean importRomFromUri(Uri uri)
+	{
+		java.io.File out = romFile();
+		try {
+			java.io.InputStream in = getContentResolver().openInputStream(uri);
+			java.io.OutputStream os = new java.io.FileOutputStream(out);
+			byte[] buf = new byte[65536];
+			int n;
+			while ((n = in.read(buf)) > 0) os.write(buf, 0, n);
+			os.close();
+			in.close();
+		} catch (Exception e) {
+			Log.e("MainMenuActivity", "ROM import failed", e);
+			if (out.exists()) out.delete();
+			return false;
+		}
+		// Validation legere : entete ZIP "PK\3\4". FBNeo verifiera le romset lui-meme.
+		try {
+			java.io.InputStream chk = new java.io.FileInputStream(out);
+			byte[] sig = new byte[4];
+			int r = chk.read(sig);
+			chk.close();
+			boolean isZip = (r == 4 && sig[0] == 'P' && sig[1] == 'K' && sig[2] == 3 && sig[3] == 4);
+			if (!isZip) { out.delete(); return false; }
+		} catch (Exception e) {
+			return false;
+		}
+		return true;
+	}
