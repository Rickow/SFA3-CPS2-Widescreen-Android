 	public static String PACKAGE_NAME;
 	boolean checkPermissions = false;
 
+	// Richard: AUTO-BOOT single game (SFA3 widescreen).
+	final private static String BUNDLED_CORE = "libfbneo_libretro_android.so"; // jniLib name
+	final private static String BUNDLED_ROM  = "sfa3.zip";                      // asset name
+
+	// Copie la ROM bundled (assets/) vers filesDir au 1er lancement, renvoie son chemin.
+	private String prepareBundledRom()
+	{
+		java.io.File outFile = new java.io.File(getFilesDir(), BUNDLED_ROM);
+		if (!outFile.exists() || outFile.length() == 0) {
+			try {
+				java.io.InputStream in = getAssets().open(BUNDLED_ROM);
+				java.io.OutputStream out = new java.io.FileOutputStream(outFile);
+				byte[] buf = new byte[65536];
+				int n;
+				while ((n = in.read(buf)) > 0) out.write(buf, 0, n);
+				out.close();
+				in.close();
+			} catch (java.io.IOException e) {
+				Log.e("MainMenuActivity", "Failed to extract bundled ROM", e);
+			}
+		}
+		return outFile.getAbsolutePath();
+	}
+
